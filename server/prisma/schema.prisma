generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  username      String   @unique
  password_hash String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile            UserProfile?
  wallets            WalletAccount[]
  contactsOwned      Contact[]     @relation("ContactOwner")
  contactsAsTarget   Contact[]     @relation("ContactTarget")
  sentTransfers      Transfer[]    @relation("TransferSender")
  receivedTransfers  Transfer[]    @relation("TransferReceiver")
  sentMessages       Message[]     @relation("MessageSender")
  receivedMessages   Message[]     @relation("MessageReceiver")
}

model UserProfile {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  full_name   String?
  avatar_url  String?
  bio         String?
  trust_score Int     @default(100)
}

model WalletAccount {
  id             String  @id @default(cuid())
  userId         String
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  public_address String
  label          String?
  is_primary     Boolean @default(false)

  @@unique([public_address])
  @@index([userId])
}

model Contact {
  id              String  @id @default(cuid())
  owner_id        String
  contact_user_id String?
  saved_pubkey    String?
  display_name    String?
  is_recent       Boolean @default(false)
  owner           User    @relation("ContactOwner", fields: [owner_id], references: [id], onDelete: Cascade)
  contactUser     User?   @relation("ContactTarget", fields: [contact_user_id], references: [id], onDelete: Cascade)

  @@index([owner_id])
}

model Transfer {
  id              String   @id @default(cuid())
  sender_id       String
  receiver_id     String?
  receiver_pubkey String?
  amount_ui       String
  amount_usd      Float?
  status          String
  is_private      Boolean  @default(false)
  tx_hash         String?
  createdAt       DateTime @default(now())

  sender   User      @relation("TransferSender", fields: [sender_id], references: [id])
  receiver User?     @relation("TransferReceiver", fields: [receiver_id], references: [id])
  messages Message[]
}

model Message {
  id                  String   @id @default(cuid())
  sender_id           String
  receiver_id         String?
  receiver_pubkey     String?
  text                String
  related_transfer_id String?
  createdAt           DateTime @default(now())

  sender   User      @relation("MessageSender", fields: [sender_id], references: [id])
  receiver User?     @relation("MessageReceiver", fields: [receiver_id], references: [id])
  transfer Transfer? @relation(fields: [related_transfer_id], references: [id])

  @@index([sender_id, receiver_id])
}
