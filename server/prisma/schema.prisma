// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  passwordHash String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  profile        UserProfile?
  walletAccounts WalletAccount[]
  contactsOwned   Contact[] @relation("ContactOwner")
  contactsReceived Contact[] @relation("ContactUser")
  transfersSent   Transfer[] @relation("TransferSender")
  transfersReceived Transfer[] @relation("TransferReceiver")
  messagesSent    Message[] @relation("MessageSender")
  messagesReceived Message[] @relation("MessageReceiver")
}

model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  fullName  String?
  avatarUrl String?
  bio       String?
  trustScore Int    @default(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WalletAccount {
  id           String   @id @default(cuid())
  userId       String
  publicAddress String  @unique // Solana public key
  label        String?
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Contact {
  id           String   @id @default(cuid())
  ownerId      String
  contactUserId String
  displayName  String?
  isRecent     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner       User @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  contactUser User @relation("ContactUser", fields: [contactUserId], references: [id], onDelete: Cascade)

  @@unique([ownerId, contactUserId])
}

model Transfer {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String
  amountUi    Float    // Human-readable amount (e.g., 1.5 SOL)
  amountUsd   Float?
  status      String   @default("pending") // pending, completed, failed
  isPrivate   Boolean  @default(false) // true if using Cloak shielded pool
  txHash      String?
  cloakDepositHash String? // For shielded transfers
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sender   User      @relation("TransferSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User      @relation("TransferReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  messages Message[]
}

model Message {
  id              String   @id @default(cuid())
  senderId        String
  receiverId      String
  text            String?
  relatedTransferId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sender        User      @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver      User      @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  relatedTransfer Transfer? @relation(fields: [relatedTransferId], references: [id], onDelete: SetNull)
}
